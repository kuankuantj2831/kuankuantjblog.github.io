{
  "name": "hakimi-blog-rn",
  "version": "1.0.0",
  "description": "Hakimi Blog React Native App",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace HakimiBlog.xcworkspace -scheme HakimiBlog -configuration Release",
    "codepush:android": "appcenter codepush release-react -a mcock/HakimiBlog-Android -d Production",
    "codepush:ios": "appcenter codepush release-react -a mcock/HakimiBlog-iOS -d Production"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.6",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/stack": "^6.3.20",
    "@react-native-async-storage/async-storage": "^1.19.3",
    "@react-native-community/netinfo": "^11.1.0",
    "react-native-gesture-handler": "^2.13.4",
    "react-native-reanimated": "^3.5.4",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-screens": "^3.27.0",
    "react-native-vector-icons": "^10.0.2",
    "react-native-webview": "^13.6.3",
    "react-native-render-html": "^6.3.4",
    "axios": "^1.6.2",
    "react-query": "^3.39.3",
    "zustand": "^4.4.7",
    "react-native-code-push": "^8.1.0",
    "react-native-push-notification": "^8.1.1",
    "@react-native-firebase/app": "^18.7.1",
    "@react-native-firebase/messaging": "^18.7.1",
    "react-native-share": "^10.0.0",
    "react-native-image-picker": "^7.0.3",
    "react-native-device-info": "^10.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/runtime": "^7.23.5",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@types/react": "^18.2.42",
    "@types/react-native": "^0.72.8",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "react-native"
  }
}
